# =============================================================================
# 서브컬처 팝업 트래커 — 전체 환경변수 마스터
# =============================================================================
#
# 사용법:
#   1) 이 파일을 루트에서 복사: cp .env.example .env.local
#   2) 패키지별 복사:
#      backend/api   → cp .env.example backend/api/.env.local
#      crawler       → cp .env.example backend/crawler/.env.local
#      frontend      → cp .env.example frontend/.env.local  (VITE_* 만 사용됨)
#
# AWS 운영 환경에서는 Secrets Manager·CDK Context를 사용하므로
# DB_PASSWORD, NAVER_CLIENT_SECRET 등은 Lambda에 직접 주입하지 않음.
# 로컬 개발·SAM Local 용도로만 이 파일을 사용한다.
#
# ⚠️  이 파일은 Git에 커밋된다. 실제 시크릿은 .env.local 에만 입력할 것.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# [공통] AWS
# ─────────────────────────────────────────────────────────────────────────────

AWS_REGION=ap-northeast-2

# CDK 배포 시 필요 (로컬 cdk deploy / bootstrap 용)
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=ap-northeast-2


# ─────────────────────────────────────────────────────────────────────────────
# [공통] Aurora PostgreSQL
#   로컬: Docker postgres:15 직접 연결
#   AWS:  DB_SECRET_ARN 으로 Secrets Manager 경유 — DB_PASSWORD 불필요
# ─────────────────────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_NAME=subculture_tracker
DB_USER=postgres
DB_PASSWORD=password

# AWS 운영 환경 전용 (로컬에서는 비워둠)
DB_SECRET_ARN=


# ─────────────────────────────────────────────────────────────────────────────
# [공통] Naver API
#
# ── Naver Developers (openapi.naver.com) ──────────────────────────────────
#   용도: Local Search API (장소명 → 좌표)
#   발급: https://developers.naver.com/apps/#/register
#         사용 API: 검색 → 지역
# ─────────────────────────────────────────────────────────────────────────────

NAVER_CLIENT_ID=neTZb8ckeWDdbD10RRni
NAVER_CLIENT_SECRET=S1nWIkKj5K

# AWS 운영 환경 전용 (Secrets Manager ARN)
NAVER_SECRET_ARN=

# ── Naver Cloud Platform (NCP) ────────────────────────────────────────────
#   용도: Dynamic Map (JS SDK), Static Map (REST), Geocoding (REST)
#   발급: https://console.ncloud.com
#         → Application 등록 → Maps 서비스 선택 (Web Dynamic Map / Static Map / Geocoding)
#
#   ⚠️  Naver Developers(openapi.naver.com) 계정과 별개의 NCP 계정 필요
#       현재 neTZb8ckeWDdbD10RRni 는 openapi.naver.com 전용 → NCP API 인증 불가 (401)
#
#   API별 인증 방식:
#     Dynamic Map (JS SDK) : <script ncpClientId="NCP_CLIENT_ID"> — 시크릿 불필요
#     Static Map (REST)    : 헤더 X-NCP-APIGW-API-KEY-ID + X-NCP-APIGW-API-KEY — 서버 전용
#     Geocoding (REST)     : 헤더 X-NCP-APIGW-API-KEY-ID + X-NCP-APIGW-API-KEY — 서버 전용
#
#   ⚠️  NCP_CLIENT_SECRET 은 브라우저에 절대 노출 금지 (서버 사이드 전용)
# ─────────────────────────────────────────────────────────────────────────────

# NCP 클라이언트 ID — Dynamic Map(프론트), Static Map, Geocoding(백엔드) 공통
NCP_CLIENT_ID=

# NCP 클라이언트 시크릿 — Static Map / Geocoding 백엔드 REST 호출 전용
NCP_CLIENT_SECRET=

# AWS 운영 환경 전용: NCP 크리덴셜을 Secrets Manager 에 저장한 경우 ARN 입력
NCP_SECRET_ARN=


# ─────────────────────────────────────────────────────────────────────────────
# [backend/api] Lambda 환경변수
# ─────────────────────────────────────────────────────────────────────────────

# ElastiCache Redis
#   로컬: Docker redis:7  /  AWS: ElastiCache 클러스터 엔드포인트
REDIS_URL=redis://localhost:6379

# EventBridge
EVENT_BUS_NAME=subculture-tracker-bus

# WebSocket 연결 테이블
WS_CONNECTION_TABLE=ws-connections


# ─────────────────────────────────────────────────────────────────────────────
# [backend/crawler] Lambda 환경변수
# ─────────────────────────────────────────────────────────────────────────────

# DynamoDB 원본 저장 테이블
DYNAMO_TABLE=crawler-raw-items-dev

# SQS 크롤러 큐 URL (SAM Local 트리거용)
SQS_QUEUE_URL=https://sqs.ap-northeast-2.amazonaws.com/123456789012/crawler-queue-dev

# Twitter (미구현 — B-003 백로그)
# TWITTER_BEARER_TOKEN_SECRET_ARN=

# S3 원본 HTML 아카이브 버킷 (미구현 — 백로그)
# S3_RAW_BUCKET=subculture-tracker-raw-dev

# SAM Local 전용 (AWS 자격증명 모킹)
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local


# ─────────────────────────────────────────────────────────────────────────────
# [frontend] Vite 환경변수  (VITE_ 접두어만 브라우저에 노출됨)
# ─────────────────────────────────────────────────────────────────────────────

# API Gateway 엔드포인트
#   로컬: SAM Local / AWS: API Gateway URL
VITE_API_URL=http://localhost:3000

# WebSocket 엔드포인트
#   로컬: 미사용 / AWS: API Gateway WebSocket URL
VITE_WS_URL=wss://xxxxxxxxxx.execute-api.ap-northeast-2.amazonaws.com/dev

# Naver Maps JavaScript SDK (NCP 클라이언트 ID)
#   = NCP_CLIENT_ID 와 동일한 값. Naver Developers NAVER_CLIENT_ID 와 다름
#   Dynamic Map 전용 — 브라우저에 노출되어도 안전 (SDK 로드에만 사용)
VITE_NAVER_MAP_CLIENT_ID=

# ⚠️  Static Map / Geocoding 시크릿은 브라우저에 절대 노출 금지
#     이 파일에 VITE_NCP_CLIENT_SECRET 을 추가하지 말 것
#     Static Map 이미지는 백엔드 API 경유로 제공 (서버가 NCP_CLIENT_SECRET 보유)

# Cognito
#   로컬: VITE_AUTH_BYPASS=true 설정 시 인증 우회
VITE_AUTH_BYPASS=true
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-northeast-2
