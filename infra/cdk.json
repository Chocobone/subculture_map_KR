{
  "app": "npx ts-node -P tsconfig.json --prefer-ts-exts bin/app.ts",
  "watch": {
    "include": ["**"],
    "exclude": ["README.md", "cdk*.json", "**/*.js", "**/*.d.ts", "node_modules", "dist", "cdk.out"]
  },
  "context": {
    "@aws-cdk/aws-lambda:recognizeLayerVersion": true,
    "@aws-cdk/core:checkSecretUsage": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "dev": {
      "auroraMinCapacity": 0,
      "auroraMaxCapacity": 1,
      "domainName": "subculture.chocobone.dev"
    },
    "prod": {
      "auroraMinCapacity": 1,
      "auroraMaxCapacity": 8,
      "domainName": "subculture.chocobone.dev"
    }
  }
}
