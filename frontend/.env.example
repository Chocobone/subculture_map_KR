# =============================================================================
# frontend 환경변수  (VITE_ 접두어만 브라우저에 노출됨)
# 루트 .env.example 에서 복사:  cp ../.env.example .env.local
# 또는 이 파일 복사:             cp .env.example .env.local
# =============================================================================
# 사용 변수 목록 (루트 .env.example 의 해당 섹션 참고)
#   [frontend] VITE_*

# ── API 엔드포인트 ─────────────────────────────────────────────────────────────
# 로컬: SAM Local (http://localhost:3000)
# AWS:  API Gateway REST URL
VITE_API_URL=http://localhost:3000

# WebSocket 엔드포인트 (실시간 알림, 미구현)
VITE_WS_URL=wss://xxxxxxxxxx.execute-api.ap-northeast-2.amazonaws.com/dev

# ── Naver Maps JavaScript SDK (NCP 클라이언트 ID) ──────────────────────────────
# 사용: Dynamic Map JS SDK (인터랙티브 지도 + 핀)
# 출처: 루트 .env.example 의 NCP_CLIENT_ID 와 동일한 값
# 발급: https://console.ncloud.com → Maps → Web Dynamic Map 서비스 등록 후 발급
# ⚠️  Naver Developers NAVER_CLIENT_ID(openapi.naver.com)와 다른 플랫폼·다른 키
VITE_NAVER_MAP_CLIENT_ID=

# ⚠️  Static Map / Geocoding 시크릿(NCP_CLIENT_SECRET)은 브라우저 노출 금지
#     VITE_NCP_CLIENT_SECRET 변수는 이 파일에 절대 추가하지 말 것
#     Static Map 이미지 → 백엔드 /api/map/static 엔드포인트 경유 제공 예정

# ── 인증 (Cognito) ────────────────────────────────────────────────────────────
# 로컬 개발: VITE_AUTH_BYPASS=true 로 Cognito 우회
# 운영 배포: false 로 변경 + Cognito 정보 입력
VITE_AUTH_BYPASS=true
VITE_COGNITO_USER_POOL_ID=ap-northeast-2_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_COGNITO_REGION=ap-northeast-2
