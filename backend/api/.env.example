# =============================================================================
# backend/api 환경변수
# 루트 .env.example 에서 복사:  cp ../../.env.example .env.local
# 또는 이 파일 복사:             cp .env.example .env.local
# =============================================================================
# 사용 변수 목록 (루트 .env.example 의 해당 섹션 참고)
#   [공통] AWS, Aurora PostgreSQL, Naver API
#   [backend/api] Redis, EventBridge, WebSocket

# ── [공통] AWS ────────────────────────────────────────────────────────────────
AWS_REGION=ap-northeast-2

# ── [공통] Aurora PostgreSQL ──────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=subculture_tracker
DB_USER=postgres
DB_PASSWORD=password
DB_SECRET_ARN=

# ── [공통] Naver Developers (Local Search API — 장소명 → 좌표) ────────────────
NAVER_CLIENT_ID=neTZb8ckeWDdbD10RRni
NAVER_CLIENT_SECRET=S1nWIkKj5K
# AWS 운영 환경 전용
NAVER_SECRET_ARN=

# ── [공통] Naver Cloud Platform (NCP — Static Map / Geocoding REST API) ────────
# 발급: https://console.ncloud.com → Maps 서비스 등록
# NCP_CLIENT_SECRET 은 서버 전용 — 프론트엔드 .env 에 절대 추가 금지
NCP_CLIENT_ID=
NCP_CLIENT_SECRET=
# AWS 운영 환경 전용
NCP_SECRET_ARN=

# ── [backend/api] ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
EVENT_BUS_NAME=subculture-tracker-bus
WS_CONNECTION_TABLE=ws-connections
