# =============================================
# backend/api 환경 변수
# 복사: cp .env.example .env.local
# =============================================

# ── Aurora PostgreSQL (로컬: Docker, 운영: Secrets Manager 자동 관리) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=subculture_tracker
DB_USER=postgres
DB_PASSWORD=password

# ── Aurora (AWS 운영 환경) ──
# Secrets Manager ARN — Lambda에서 자동으로 크리덴셜을 가져옴
# 로컬 개발 시에는 위 DB_* 직접 입력값을 사용하므로 비워둬도 됨
DB_SECRET_ARN=

# ── ElastiCache Redis ──
# 로컬: Docker Redis / 운영: ElastiCache 엔드포인트
REDIS_URL=redis://localhost:6379

# ── Naver Local Search API ──
# 발급: https://developers.naver.com/apps/#/register
# 사용 API: 검색 → 지역
NAVER_CLIENT_ID=neTZb8ckeWDdbD10RRni
NAVER_CLIENT_SECRET=S1nWIkKj5K

# ── AWS ──
AWS_REGION=ap-northeast-2

# ── 기타 Lambda 환경 변수 ──
EVENT_BUS_NAME=subculture-tracker-bus
WS_CONNECTION_TABLE=ws-connections
